// @file Prisma schema for the Phase 1 foundational identity and project models.
// @author PopoY
// @created 2026-06-04

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberStatus {
  INVITED
  ACTIVE
  SUSPENDED
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ProjectRole {
  PROJECT_OWNER
  SCRUM_MASTER
  DEVELOPER
  REVIEWER
}

model User {
  id              String          @id @default(uuid())
  email           String          @unique
  displayName     String
  teamMemberships TeamMember[]
  projectMembers  ProjectMember[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model Team {
  id          String       @id @default(uuid())
  name        String
  members     TeamMember[]
  projects    Project[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model TeamMember {
  id         String       @id @default(uuid())
  teamId     String
  userId     String
  status     MemberStatus
  joinedAt   DateTime?
  team       Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([teamId, userId])
}

model Project {
  id          String          @id @default(uuid())
  teamId      String
  key         String          @unique
  name        String
  status      ProjectStatus
  team        Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  members     ProjectMember[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model ProjectMember {
  id         String       @id @default(uuid())
  projectId  String
  userId     String
  role       ProjectRole
  status     MemberStatus
  project    Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@unique([projectId, userId])
}
