# @file EditorConfig baseline for the Phase 1 bootstrap task
# @author PopoY
# @created 2026-06-04
# @purpose Keep whitespace, indentation, and newline rules consistent across the monorepo workspaces.

root = true

[*.{ts,tsx,js,json,md,yaml,yml}]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false
