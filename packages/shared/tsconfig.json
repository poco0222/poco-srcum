{
  // @file Shared package TypeScript config
  // @author PopoY
  // @created 2026-06-04
  // @purpose Configure shared DTO and validation schema sources with strict TypeScript defaults.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "rootDir": "./src",
    "noEmit": true
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
